# ============================================
# AuraPay Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED for Production
# ============================================

# JWT Secret - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secret-key-at-least-32-characters-long

# Turso Database (https://turso.tech)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Dentally API (https://developer.dentally.co)
DENTALLY_API_TOKEN=your-dentally-api-token

# ============================================
# OPTIONAL Configuration
# ============================================

# Dentally Site ID (uses default if not set)
# DENTALLY_SITE_ID=your-site-id

# Google Service Account for Google Sheets integration
# Base64 encode your service account JSON:
#   cat service-account.json | base64 -w 0
# GOOGLE_SERVICE_ACCOUNT_JSON=base64-encoded-json

# SMTP Configuration for sending payslip emails
# These can also be configured in the Settings page
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=payslips@yourdomain.com

# Initial Admin Password (for first deployment)
# If not set, a random password will be generated and logged
# INITIAL_ADMIN_PASSWORD=change-me-immediately

# ============================================
# Development Only
# ============================================

# NODE_ENV is automatically set by Vercel
# For local development:
# NODE_ENV=development
